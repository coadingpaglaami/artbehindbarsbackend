model Artist {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  lifeSentence   String
  facilityName   String
  inmateId       String
  state          String
  minReleaseDate DateTime
  maxReleaseDate DateTime
  image          String

  createdById String? @db.Uuid
  createdBy   User?   @relation("ArtistCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  artworks  Artwork[]
  createdAt DateTime  @default(now())
}
