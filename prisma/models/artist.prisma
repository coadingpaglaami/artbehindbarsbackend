model Artist {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  lifeSentence   String
  facilityName   String
  inmateId       String
  state          String
  minReleaseDate DateTime
  maxReleaseDate DateTime
  createdById    String?   @db.Uuid
  createdAt      DateTime  @default(now())
  image          String
  createdBy      User?     @relation("ArtistCreatedBy", fields: [createdById], references: [id])
  artworks       Artwork[]
  fanMails       FanMail[]
}
