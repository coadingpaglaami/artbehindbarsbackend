model Artwork {
  id               String   @id @default(uuid()) @db.Uuid
  imageUrl         String
  title            String?
  isAnonymous      Boolean  @default(false)
  category         Category
  buyItNowPrice    Float
  startingBidPrice Float?   @default(0)
  artistId         String?  @db.Uuid
  uploadedById     String?  @db.Uuid
  createdAt        DateTime @default(now())
  artist           Artist?  @relation(fields: [artistId], references: [id])
  uploadedBy       User?    @relation("ArtworkUploadedBy", fields: [uploadedById], references: [id])
  auction          Auction?
}

enum Category {
  Religious
  Non_Religious
}
