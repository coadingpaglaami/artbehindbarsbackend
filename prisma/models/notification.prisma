model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  type      NotificationType @default(INFO) // ✅ new field

  user User @relation(fields: [userId], references: [id])
}

enum NotificationType {
  PAYMENT // Auction or payment related
  LIKE // Someone liked your post/artwork
  COMMENT // Comment on your post/artwork
  ADMIN // Admin message, warnings
  INFO // General info
}
