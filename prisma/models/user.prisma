model User {
  id                  String            @id @default(uuid()) @db.Uuid
  email               String            @unique
  pendingEmail        String?           @unique
  firstName           String
  lastName            String
  password            String?
  role                Role              @default(USER)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  dateOfBirth         DateTime
  otp                 String?
  otpExpiry           DateTime?
  oauthProvider       String?
  isSuspended         Boolean           @default(false)
  suspendedUntil      DateTime?
  bio                 String?
  profilePictureUrl   String?
  location            String?
  point               Int               @default(0)
  otpType             OtpType?
  createdArtists      Artist[]          @relation("ArtistCreatedBy")
  uploadedArtworks    Artwork[]         @relation("ArtworkUploadedBy")
  auctionBids         AuctionBid[]
  chatParticipants    ChatParticipant[]
  comments            Comment[]
  receivedConnections Connection[]      @relation("Receiver")
  sentConnections     Connection[]      @relation("Requester")
  fanMails            FanMail[]
  fanMailReplies      FanMailReply[]
  likes               Like[]
  messages            Message[]
  messageStatuses     MessageStatus[]
  orders              Order[]           @relation("UserOrders")
  posts               Post[]
  reports             Report[]

  blockedUsers UserBlock[] @relation("Blocker")
  blockedBy    UserBlock[] @relation("Blocked")

  notifications Notification[]

  auctions          Auction[]
  userActivities    UserActivity[]
  pointTransactions PointTransaction[]
}

enum Role {
  USER
  ADMIN
}

enum OtpType {
  signup
  resetPassword
  emailChange
  newEmailVerification
}

model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

enum IsActive {
  ACTIVE
  INACTIVE
  SUSPEND
}

enum ActivityType {
  BUY_PRODUCT
  CREATE_POST
  COMMENT
  LIKE
  BID
  SEND_FANMAIL
}

model UserActivity {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  type      ActivityType
  refId     String?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model PointTransaction {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  activity  UserActivityType
  points    Int
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserActivityType {
  BUY_PRODUCT
  CREATE_POST
  COMMENT
  LIKE
  BID
  SEND_FANMAIL
}
