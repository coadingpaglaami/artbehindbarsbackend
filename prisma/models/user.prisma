model User {
  id                  String             @id @default(uuid()) @db.Uuid
  email               String             @unique
  pendingEmail        String?            @unique
  firstName           String
  lastName            String
  password            String?
  role                Role               @default(USER)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  dateOfBirth         DateTime
  otp                 String?
  otpExpiry           DateTime?
  oauthProvider       String?
  isSuspended         Boolean            @default(false)
  suspendedUntil      DateTime?
  bio                 String?
  profilePictureUrl   String?
  location            String?
  point               Int                @default(0)
  otpType             OtpType?
  createdArtists      Artist[]           @relation("ArtistCreatedBy")
  uploadedArtworks    Artwork[]          @relation("ArtworkUploadedBy")
  auctions            Auction[]
  auctionBids         AuctionBid[]
  chatParticipants    ChatParticipant[]
  comments            Comment[]
  receivedConnections Connection[]       @relation("Receiver")
  sentConnections     Connection[]       @relation("Requester")
  fanMails            FanMail[]
  fanMailReplies      FanMailReply[]
  likes               Like[]
  messages            Message[]
  messageStatuses     MessageStatus[]
  notifications       Notification[]
  orders              Order[]            @relation("UserOrders")
  pointTransactions   PointTransaction[]
  posts               Post[]
  reports             Report[]
  userActivities      UserActivity[]
  blockedBy           UserBlock[]        @relation("Blocked")
  blockedUsers        UserBlock[]        @relation("Blocker")
}

model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])

  @@unique([blockerId, blockedId])
}

model UserActivity {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  type      ActivityType
  refId     String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model PointTransaction {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  activity  UserActivityType
  points    Int
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum OtpType {
  signup
  resetPassword
  emailChange
  newEmailVerification
}

enum IsActive {
  ACTIVE
  INACTIVE
  SUSPEND
}

enum ActivityType {
  BUY_PRODUCT
  CREATE_POST
  COMMENT
  LIKE
  BID
  SEND_FANMAIL
}

enum UserActivityType {
  BUY_PRODUCT
  CREATE_POST
  COMMENT
  LIKE
  BID
  SEND_FANMAIL
}
