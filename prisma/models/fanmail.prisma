enum FanMailStatus {
  PENDING // user sent, no reply yet
  REPLIED // admin replied as artist
  CLOSED // optional, if you want final state
}

model FanMail {
  id String @id @default(uuid()) @db.Uuid

  artistId     String @db.Uuid
  senderUserId String @db.Uuid // ✅ FIXED

  subject String?
  message String

  status     FanMailStatus @default(PENDING)
  isArchived Boolean       @default(false)

  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sender         User           @relation(fields: [senderUserId], references: [id])
  artist         Artist         @relation(fields: [artistId], references: [id])
  fanMailReplies FanMailReply[]

  @@index([artistId])
  @@index([senderUserId])
}

model FanMailReply {
  id String @id @default(uuid()) @db.Uuid

  fanMailId String @db.Uuid
  adminId   String @db.Uuid // must match User.id

  message   String
  createdAt DateTime @default(now())

  fanMail FanMail @relation(fields: [fanMailId], references: [id])
  admin   User    @relation(fields: [adminId], references: [id])
}
